# Copy this file to docker/pi.env and fill only the provider key you want to use.
# Never bake real API keys into Dockerfile.test.

# Pi quick-start default. Works with Anthropic-backed models.
ANTHROPIC_API_KEY=

# Alternative providers supported by Pi. Leave unused providers blank or remove them.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# Keep Docker smoke runs quieter and less network-chatty at startup.
PI_SKIP_VERSION_CHECK=1
PI_TELEMETRY=0
