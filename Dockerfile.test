FROM node:22-bookworm-slim

WORKDIR /app

ENV CI=true

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    g++ \
    git \
    make \
    python3 \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./

RUN npm ci

RUN npm install -g --ignore-scripts @earendil-works/pi-coding-agent@0.80.2

COPY . .

CMD ["npm", "test"]
